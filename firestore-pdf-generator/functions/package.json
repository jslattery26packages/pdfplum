{
  "name": "pdfplum",
  "version": "0.19.0",
  "description": "Generate PDF documents from templates stored in Firebase Storage",
  "author": "PDFPlum (hi@pdfplum.com)",
  "repository": "https://github.com/pdfplum/pdfplum",
  "scripts": {
    "lint": "eslint .",
    "format": "eslint --fix .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf ./build/",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "test": "jest"
  },
  "engines": {
    "node": "22"
  },
  "main": "build/src/index.js",
  "dependencies": {
    "@sparticuz/chromium": "149.0.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.18.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.2.5",
    "firebase-functions-test": "^3.5.0",
    "get-port-please": "^3.2.0",
    "googleapis": "^173.0.0",
    "handlebars": "^4.7.9",
    "handlebars-helpers": "^0.10.0",
    "jest": "^30.4.2",
    "jszip": "^3.10.1",
    "module-alias": "^2.3.4",
    "path": "^0.12.7",
    "puppeteer-core": "^22.13.1",
    "serve-static": "^2.2.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "_moduleAliases": {
    "lib": "build/lib",
    "src": "build/src"
  },
  "devDependencies": {
    "puppeteer": "^24.16.0"
  },
  "overrides": {
    "jwa": "^2.0.0"
  },
  "license": "Apache-2.0"
}